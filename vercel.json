{
    "version": 2,
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/index.py"
        },
        {
            "source": "/static/(.*)",
            "destination": "/frontend/kibana-plugin/build/static/$1"
        },
        {
            "source": "/(.*)\\.(js|css|png|jpg|svg|ico|json)",
            "destination": "/frontend/kibana-plugin/build/$1.$2"
        },
        {
            "source": "/(.*)",
            "destination": "/frontend/kibana-plugin/build/index.html"
        }
    ],
    "env": {
        "REACT_APP_API_URL": "/api/datapulse/v1"
    }
}