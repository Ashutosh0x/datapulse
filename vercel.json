{
    "version": 2,
    "installCommand": "npm install",
    "buildCommand": "cd frontend/kibana-plugin && npm install --legacy-peer-deps && CI=false npm run build && cd ../.. && rm -rf public && cp -R frontend/kibana-plugin/build public",
    "outputDirectory": "public",
    "functions": {
        "api/index.py": {
            "runtime": "@vercel/python"
        }
    },
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/index.py"
        },
        {
            "source": "/static/(.*)",
            "destination": "/static/$1"
        },
        {
            "source": "/(.*)\\.(js|css|png|jpg|svg|ico|json)",
            "destination": "/$1.$2"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ],
    "env": {
        "REACT_APP_API_URL": "/api/datapulse/v1"
    }
}