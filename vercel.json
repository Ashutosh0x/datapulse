{
    "version": 2,
    "builds": [
        {
            "src": "api/index.py",
            "use": "@vercel/python",
            "config": {
                "runtime": "python3.11"
            }
        },
        {
            "src": "package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "frontend/kibana-plugin/build",
                "installCommand": "npm install && cd frontend/kibana-plugin && npm install",
                "buildCommand": "cd frontend/kibana-plugin && npm run build"
            }
        }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "api/index.py"
        },
        {
            "source": "/(.*)",
            "destination": "package.json"
        }
    ],
    "env": {
        "REACT_APP_API_URL": "/api/datapulse/v1"
    }
}