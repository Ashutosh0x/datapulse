{
    "version": 2,
    "functions": {
        "backend/api_gateway/src/main.py": {
            "runtime": "@vercel/python"
        }
    },
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/backend/api_gateway/src/main.py"
        },
        {
            "source": "/static/(.*)",
            "destination": "/static/$1"
        },
        {
            "source": "/(.*)\\.(js|css|png|jpg|svg|ico|json)",
            "destination": "/$1.$2"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ],
    "env": {
        "REACT_APP_API_URL": "/api/datapulse/v1"
    }
}